#!/usr/bin/env bash
# Code Brain hook shim. Resolves project root via:
#   1) $CLAUDE_PROJECT_DIR / $CODEX_PROJECT_DIR if set
#   2) Script-relative path (this file should live at <root>/.ai/bin/ai-hook)
#   3) Walk-up search from cwd for .ai/config.yaml
# Fails open (exit 0) if root cannot be resolved, so the hook never blocks the
# user's underlying tool call by accident.
set -uo pipefail

resolve_root() {
  local candidate
  for candidate in "${CLAUDE_PROJECT_DIR:-}" "${CODEX_PROJECT_DIR:-}"; do
    if [[ -n "$candidate" && -f "$candidate/.ai/config.yaml" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  local script_dir
  if script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)"; then
    if [[ -f "$script_dir/../../.ai/config.yaml" ]]; then
      (cd "$script_dir/../.." && pwd)
      return 0
    fi
  fi
  local cur
  cur="$(pwd 2>/dev/null || printf '/')"
  while [[ -n "$cur" && "$cur" != "/" ]]; do
    if [[ -f "$cur/.ai/config.yaml" ]]; then
      printf '%s\n' "$cur"
      return 0
    fi
    cur="$(dirname "$cur")"
  done
  return 1
}

ROOT="$(resolve_root || true)"
if [[ -z "${ROOT:-}" ]]; then
  echo "ai-hook: cannot locate code-brain project root (no .ai/config.yaml found)" >&2
  exit 0
fi
cd "$ROOT"
export PYTHONDONTWRITEBYTECODE="${PYTHONDONTWRITEBYTECODE:-1}"
export AI_CODE_BRAIN_PROFILE="${AI_CODE_BRAIN_PROFILE:-usage}"
export AI_SKILL_RECOMMENDATIONS="${AI_SKILL_RECOMMENDATIONS:-0}"
export AI_AGENT_RECOMMENDATIONS="${AI_AGENT_RECOMMENDATIONS:-0}"
export AI_PRECALL_RECOMMENDATIONS="${AI_PRECALL_RECOMMENDATIONS:-0}"
export AI_FEDERATED_SUMMARY="${AI_FEDERATED_SUMMARY:-0}"
export AI_SATISFACTION_SUMMARY="${AI_SATISFACTION_SUMMARY:-0}"
PYTHON="$ROOT/.ai/runtime/.venv/bin/python"
if [[ -x "$PYTHON" ]] && "$PYTHON" -c 'import ai_core.cli' >/dev/null 2>&1; then
  exec "$PYTHON" -m ai_core.cli hook "$@"
fi
exec uv run --project "$ROOT/.ai/runtime" python -m ai_core.cli hook "$@"
