{
  "_note": "Code Brain Codex hooks. Keep this in the current Codex matcher-group schema: event -> matcher -> hooks[].",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PermissionRequest",
            "statusMessage": "Checking Code Brain approval policy",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PostCompact",
            "statusMessage": "Recording Code Brain compact completion",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PostToolUse",
            "statusMessage": "Recording Code Brain tool result",
            "type": "command"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write|MultiEdit|NotebookEdit|Read|Glob|Grep"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PreCompact",
            "statusMessage": "Saving Code Brain compact snapshot",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PreToolUse",
            "statusMessage": "Checking Code Brain command routing",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; AI_SKILL_RECOMMENDATIONS=0 AI_AGENT_RECOMMENDATIONS=0 AI_PRECALL_RECOMMENDATIONS=0 \"$ROOT/.ai/bin/ai-hook\" SessionStart",
            "statusMessage": "Loading Code Brain session context",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" Stop",
            "statusMessage": "Recording Code Brain stop event",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" SubagentStart",
            "statusMessage": "Loading Code Brain subagent context",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" SubagentStop",
            "statusMessage": "Recording Code Brain subagent stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" UserPromptSubmit",
            "statusMessage": "Loading Code Brain prompt context",
            "type": "command"
          }
        ]
      }
    ]
  }
}
