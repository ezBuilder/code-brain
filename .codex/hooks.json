{
  "_note": "Code Brain Codex hooks. Keep this in the current Codex matcher-group schema: event -> matcher -> hooks[].",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PermissionRequest",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" PermissionRequest\"",
            "statusMessage": "Checking Code Brain approval policy",
            "type": "command"
          }
        ],
        "matcher": "Bash|Shell|exec_command|functions.exec_command|run_command|ask_permission"
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PostCompact",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" PostCompact\"",
            "statusMessage": "Recording Code Brain compact completion",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PostToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" PostToolUse\"",
            "statusMessage": "Recording Code Brain tool result",
            "type": "command"
          }
        ],
        "matcher": "Bash|Shell|exec_command|functions.exec_command|apply_patch|Edit|Write|MultiEdit|NotebookEdit|Read|Glob|Grep|run_command|replace_file_content|multi_replace_file_content|write_to_file|view_file|grep_search|list_dir"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PreCompact",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" PreCompact\"",
            "statusMessage": "Saving Code Brain compact snapshot",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" PreToolUse",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" PreToolUse\"",
            "statusMessage": "Checking Code Brain command routing",
            "type": "command"
          }
        ],
        "matcher": "Bash|Shell|exec_command|functions.exec_command|run_command"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" SessionStart",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" SessionStart\"",
            "statusMessage": "Loading Code Brain session context",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" Stop",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" Stop\"",
            "statusMessage": "Recording Code Brain stop event",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" SubagentStart",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" SubagentStart\"",
            "statusMessage": "Loading Code Brain subagent context",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" SubagentStop",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" SubagentStop\"",
            "statusMessage": "Recording Code Brain subagent stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "ROOT=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; \"$ROOT/.ai/bin/ai-hook\" UserPromptSubmit",
            "commandWindows": "powershell -NoProfile -Command \"$ROOT = (git rev-parse --show-toplevel 2>$null); if (-not $ROOT) { $ROOT = (Get-Location).Path }; & \\\"$ROOT/.ai/bin/ai-hook.ps1\\\" UserPromptSubmit\"",
            "statusMessage": "Loading Code Brain prompt context",
            "type": "command"
          }
        ]
      }
    ]
  }
}
