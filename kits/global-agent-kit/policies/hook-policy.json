{
  "version": 2,
  "hard_deny": {
    "commands": [
      "\\brm\\s+-rf\\s+(/|~|\\*|\\.)",
      "\\bgit\\s+reset\\s+--hard\\b",
      "\\bgit\\s+clean\\s+-fd\\b",
      "\\bdropdb\\b",
      "\\bdrop\\s+database\\b",
      "\\bprisma\\s+migrate\\s+reset\\b",
      "\\bsequelize\\s+db:drop\\b",
      "\\bkubectl\\s+delete\\b",
      "\\bterraform\\s+destroy\\b",
      "\\bpulumi\\s+destroy\\b",
      "\\bgit(?:\\s+-C\\s+\\S+)?\\s+branch\\b[^\\n;&|]*(?:-d|-D|--delete)\\b[^\\n;&|]*(?<![A-Za-z0-9._/-])(?:refs/heads/)?(?:main|master|develop|development|trunk|prod|production|staging)(?![A-Za-z0-9._/-])",
      "\\bgit\\s+push\\b.*(--force\\b|--force-with-lease|\\s-f\\b)",
      "\\bgit(?:\\s+-C\\s+\\S+)?\\s+push\\b[^\\n;&|]*(?:--delete|-d)\\b[^\\n;&|]*(?<![A-Za-z0-9._/-])(?:refs/heads/)?(?:main|master|develop|development|trunk|prod|production|staging)(?![A-Za-z0-9._/-])",
      "\\bgit(?:\\s+-C\\s+\\S+)?\\s+push\\b[^\\n;&|]*(?<!\\S):(?:refs/heads/)?(?:main|master|develop|development|trunk|prod|production|staging)(?![A-Za-z0-9._/-])",
      "\\bgit\\s+filter-branch\\b",
      "\\bgit\\s+filter-repo\\b",
      "\\bgit\\s+update-ref\\s+-d\\b",
      "\\bgit\\s+reflog\\s+expire\\b"
    ],
    "paths": [
      "(^|/)\\.env($|\\.)",
      "(^|/)secrets?/",
      "credentials\\.json$",
      "\\.pem$",
      "\\.key$",
      "id_rsa$",
      "id_ed25519$"
    ]
  },
  "approval_required": {
    "commands": [
      "\\bgit\\s+(commit|push|merge|rebase)\\b",
      "\\bgh\\s+repo\\s+create\\b",
      "\\bgh\\s+workflow\\s+run\\b",
      "\\b(npm|pnpm|yarn)\\s+(install|add|publish)\\b",
      "\\b(pip\\s+install|uv\\s+add)\\b"
    ],
    "request_keywords": [
      "production",
      "deploy",
      "billing",
      "auth",
      "permission",
      "delete data",
      "database reset",
      "secret",
      "token",
      "oauth"
    ]
  },
  "workflow_nudges": {
    "research_first_keywords": [
      "latest",
      "recent",
      "current",
      "recommend",
      "library",
      "plugin",
      "mcp",
      "hook",
      "skill"
    ],
    "verification_keywords": [
      "fix",
      "bug",
      "implement",
      "upgrade",
      "refactor",
      "release"
    ]
  }
}
