{
  "name": "code-brain-remote-memory-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create code-brain-remote-memory",
    "db:migrate:remote": "wrangler d1 execute code-brain-remote-memory --remote --file=schema.sql",
    "vectors:create": "wrangler vectorize create code-brain-remote-memory-vectors --dimensions=384 --metric=cosine",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
